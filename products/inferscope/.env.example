# InferScope environment variables (copy to .env and fill in)
# NEVER commit .env files — they are gitignored

# Debug mode (enables verbose logging)
# INFERSCOPE_DEBUG=0

# Cache directory for empirical profiles
# INFERSCOPE_CACHE_DIR=~/.inferscope

# Default GPU memory utilization target
# INFERSCOPE_DEFAULT_GPU_UTIL=0.92
